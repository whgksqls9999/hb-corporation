{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/conventions-dispatch.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/inject_company.py\" || python \"${CLAUDE_PLUGIN_ROOT}/scripts/inject_company.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/track_team.py\" || python \"${CLAUDE_PLUGIN_ROOT}/scripts/track_team.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/enforce_scribe.py\" || python \"${CLAUDE_PLUGIN_ROOT}/scripts/enforce_scribe.py\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
